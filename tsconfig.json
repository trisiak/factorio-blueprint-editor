{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ES6",
        "skipLibCheck": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "noEmit": true,

        // Ratcheting toward full `strict`. These members are satisfied (zero
        // errors) so they're on now to prevent regressions. The remaining
        // `strict` family is staged by cost — flip each once its backlog is
        // cleared:
        //   "noImplicitAny": true,         // ~77 errors
        //   "strictNullChecks": true,      // ~777 errors (the big one)
        //   "strict": true,                // implies all of the above
        "alwaysStrict": true,
        "noImplicitThis": true,
        "strictBindCallApply": true,
        "strictFunctionTypes": true,
        "useUnknownInCatchVariables": true,

        "paths": {
            "@fbe/*": ["./packages/*/src/index.ts"]
        },

        "types": ["vite/client", "typed-factorio/prototype"]
    },

    // Playwright type-checks its own config/specs at runtime (they rely on Node
    // globals not in this project's `types`); keep them out of `npm run type-check`.
    "exclude": ["e2e", "playwright.config.ts"]
}
